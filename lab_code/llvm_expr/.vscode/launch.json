{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "LLVM debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/bin/LLVM_HELLO_WORLD",
            "args": [
                "test/expr.txt"
            ],
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "build",
            "stopAtEntry": false,
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}